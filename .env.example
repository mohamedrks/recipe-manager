# Application
ENVIRONMENT=development
DEBUG=false

# Database (postgresql+asyncpg://user:password@host:port/dbname)
DATABASE_URL=postgresql+asyncpg://recipe_user:recipe_pass@localhost:5432/recipe_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT — generate your secret with:
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=recipe-manager-abn-secret-amro
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
# This is just a placeholder. We don't need it as we don't have a frontend.
CORS_ORIGINS=["http://localhost:8080"]

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
